# Auth
# AUTH_SECRET: random 32-byte hex string. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=
# DASHBOARD_PASSWORD: the single password used to sign in.
DASHBOARD_PASSWORD=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers (classifier: Claude primary, OpenAI fallback + Whisper + embeddings)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Shared secret echoed by Telegram in x-telegram-bot-api-secret-token.
# Set it when registering the webhook via setWebhook(secret_token=...).
TELEGRAM_WEBHOOK_SECRET=
# Numeric Telegram user ID allowed to use the bot (everyone else is ignored).
TELEGRAM_USER_ID=
